{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    { "src": "/leaderboard", "dest": "/leaderboard.html" }
  ],
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
